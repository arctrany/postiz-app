# ════════════════════════════════════════════
#  XPoz + Huginn 统一部署环境变量
#  复制为 .env 并修改所有 change-me 值
# ════════════════════════════════════════════

# ─── 域名配置 ───
XPOZ_DOMAIN=xpoz.example.com
HUGINN_DOMAIN=huginn.example.com
TEMPORAL_DOMAIN=temporal.example.com
XPOZ_URL=http://xpoz.example.com
HUGINN_URL=http://huginn.example.com

# ─── 数据库 (共用 PostgreSQL) ───
POSTGRES_USER=xpoz
POSTGRES_PASSWORD=change-me-postgres-pwd
XPOZ_DB=xpoz
HUGINN_DB=huginn

# ─── XPoz ───
JWT_SECRET=change-me-jwt-secret-min-32-chars
DISABLE_REGISTRATION=false

# ─── Temporal ───
TEMPORAL_DB_PASSWORD=change-me-temporal-pwd

# ─── Huginn ───
HUGINN_SECRET=change-me-huginn-secret-min-32-chars
HUGINN_INVITATION_CODE=change-me-invitation
HUGINN_PASSWORD=change-me-huginn-admin-pwd
TIMEZONE=Asia/Shanghai

# ─── 社媒 API Keys (按需填写) ───
X_CLIENT_ID=
X_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
THREADS_APP_ID=
THREADS_APP_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
MASTODON_URL=https://mastodon.social
MASTODON_CLIENT_ID=
MASTODON_CLIENT_SECRET=

# ─── AI (可选) ───
OPENAI_API_KEY=

# ─── 支付 (可选) ───
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
